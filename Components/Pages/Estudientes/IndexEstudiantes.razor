@page "/estudiantes"
@rendermode InteractiveServer
@if(ShowForm){
    <EditForm FormName="frmEstudiante" Model="@model" OnValidSubmit="AgregarEstudiante">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label class="form-label">Matricula</label>
            <input class="form-control" @bind="model.Matricula"/>
            <ValidationMessage For="()=> model.Matricula" />
        </div>
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input class="form-control" @bind="model.Nombre"/>
            <ValidationMessage For="()=> model.Nombre" />
        </div>
        <button type="submit" class="btn btn-success">Aceptar</button>
        <button type="button" class="btn btn-danger">Cancelar</button>
    </EditForm>
    return;
}
<div class="container py-4">
    <h1 class="text-primary mb-3">Estudiantes</h1>
    <p class="text-muted mb-4">Aquí puedes ver la lista de estudiantes registrados en la academia.</p>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-primary border-bottom">
                        <tr>
                            <th class="ps-4 py-3">#</th>
                            <th class="py-3">Matrícula</th>
                            <th class="py-3">Estudiante</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (estudiantes != null)
                        {
                            @foreach (var estudiante in estudiantes)
                            {
                                <tr>
                                    <td class="ps-4 py-3 text-secondary">@estudiante.Id</td>
                                    <td class="py-3">@estudiante.Matricula</td>
                                    <td class="py-3 fw-bold">@estudiante.Nombre</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                    Cargando estudiantes...
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private bool ShowForm = true;
    private EstudianteViewModel model = new ();

    private List<EstudianteViewModel> estudiantes = [];


    protected override async Task OnInitializedAsync()
    {
        // Obtenemos la lista de estudiantes desde el servicio
        estudiantes =  estudianteService.GetAll();

        await base.OnInitializedAsync();
    }

    private void LimpiarFormulario()
    {
        model = new ();
        ShowForm = false;
    }
    
    private void AgregarEstudiante()
    {
        // Lógica para agregar un nuevo estudiante
        if(estudianteService.Create(model))
        {
            LimpiarFormulario();
            estudiantes = estudianteService.GetAll();
        }
    }
    private void EditarEstudiante(int id)
    {
        // Lógica para editar un estudiante existente
    }
    private void EliminarEstudiante(int id)
    {
        // Lógica para eliminar un estudiante

    }
}